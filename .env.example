# DeployMonster Configuration
# Copy to .env and adjust values

# Server
MONSTER_HOST=0.0.0.0
MONSTER_PORT=8443
MONSTER_DOMAIN=localhost
MONSTER_SECRET=change-me-to-a-random-32-char-string

# Database
MONSTER_DB_PATH=./data/monster.db

# Docker
MONSTER_DOCKER_HOST=unix:///var/run/docker.sock

# SSL/ACME (Let's Encrypt)
MONSTER_ACME_EMAIL=admin@example.com

# Registration mode: open, invite, closed
MONSTER_REGISTRATION_MODE=open

# Stripe (optional, for billing)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
