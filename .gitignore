# Build output
bin/
dist/

# Web UI build
web/dist/
web/node_modules/

# npm lockfile — web/ uses pnpm, never npm. Dependabot scans any
# package-lock.json it finds, so an accidental `npm install` would
# recreate a stale lockfile and reopen already-fixed alerts. Tier 96.
web/package-lock.json

# Generated UI bundles — rebuilt on every `pnpm run build`, tracked in
# source control only for the initial migration; add to .gitignore to
# prevent committing churn on every UI change.
internal/api/static/

# Database files
*.db
*.db-wal
*.db-shm
*.bolt
backups/

# Test coverage
*.out
coverage*.html
coverage/
gosec-results.json

# Point-in-time scan / audit output — not source. Keep findings in CI
# artifacts or the wiki, not the tree.
security-report/

